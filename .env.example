# Zkopíruj do `.env` a doplň hodnoty. Soubor `.env` je v .gitignore.
# Čtou ho jak Next.js (runtime), tak Prisma CLI (migrace).

# API-Football (Pro tarif) – klíč drž jen na serveru, nikdy v klientovi.
API_FOOTBALL_KEY=

# Neon Postgres – POOLED připojení (běh aplikace, host obsahuje -pooler).
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Volitelné: tajemství pro ochranu warm/cron endpointu (GET /api/warm).
# Když je nastaveno, vyžaduje hlavičku Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# ── Auth.js (přihlašování / účty) ────────────────────────────────────────
# Náhodné tajemství pro podpis session (vygeneruj: `npx auth secret` nebo openssl).
AUTH_SECRET=
# Google OAuth (Google Cloud Console → OAuth client, web). Redirect URI:
#   http://localhost:3000/api/auth/callback/google  (a produkční varianta)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Pozn. (tento stroj): Google token exchange = odchozí TLS → spouštěj dev s
# NODE_OPTIONS=--use-system-ca. Na Vercelu netřeba.
